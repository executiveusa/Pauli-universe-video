# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Modal.com (GPU Functions)
MODAL_TOKEN_ID=your-token-id
MODAL_TOKEN_SECRET=your-token-secret

# Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Vercel
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# Higgsfield API
HIGGSFIELD_API_KEY=your-higgsfield-key
HIGGSFIELD_API_URL=https://api.higgsfield.com

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_ACCESS_KEY=your-access-key
CLOUDFLARE_SECRET_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET=pauli-assets

# Redis
REDIS_URL=redis://localhost:6379

# Neo4j
NEO4J_URL=neo4j+s://your-database.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password

# Resend (Email)
RESEND_API_KEY=your-resend-key

# Sentry
SENTRY_DSN=your-sentry-dsn

# OpenAI (for podcast generation)
OPENAI_API_KEY=sk_your_openai_key

# Application
NODE_ENV=development
LOG_LEVEL=info
