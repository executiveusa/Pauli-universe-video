# API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx
HUGGINGFACE_API_KEY=hf_xxxxx

# LLM Configuration (LiteLLM)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-1
LLM_API_KEY=${ANTHROPIC_API_KEY}

# Cloud Storage
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json
GCS_BUCKET_NAME=pauli-videos
DROPBOX_ACCESS_TOKEN=sl_xxxxx
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGc...

# Third-party Services
HYPERFRAME_API_KEY=xxxxx
MERCURY_API_KEY=xxxxx

# OAuth
OPENAI_CLIENT_ID=xxxxx
OPENAI_CLIENT_SECRET=xxxxx
OPENAI_REDIRECT_URI=http://localhost:8000/llm/callback

# Telegram & WhatsApp
TELEGRAM_BOT_TOKEN=xxxxx:xxxxx
WHATSAPP_API_TOKEN=xxxxx

# Redis (for Celery)
REDIS_URL=redis://localhost:6379

# Server
HOST=0.0.0.0
PORT=8000
